<Window x:Class="ImgCombiner.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:ImgCombiner.ViewModels"
        xmlns:conv="clr-namespace:ImgCombiner.Converters"
        mc:Ignorable="d"
        Title="图片工具" Width="1200" Height="800">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <conv:FolderPathShortenerConverter x:Key="FolderShort" MaxLen="20" MaxLevels="3"/>
        <conv:FilePathShortenerConverter x:Key="FileShort" MaxLen="55" MaxLevels="2"/>
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <TabControl>
            <!-- TAB1 -->
            <TabItem Header="格式转换">
                <Grid DataContext="{Binding Convert}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 顶部：选择文件夹 -->
                    <Border BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="10">
                        <DockPanel LastChildFill="True">
                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="添加文件夹" Padding="12,6" Margin="0,0,10,0"
                        Command="{Binding AddFolderCommand}"/>
                                <CheckBox Content="递归子文件夹" Margin="0,0,10,0"
                          IsChecked="{Binding IsRecursive}"/>
                                <CheckBox Content="隐藏已是目标格式" Margin="0,0,10,0"
                          IsChecked="{Binding HideAlreadyTargetFormat}"/>
                            </StackPanel>

                            <ItemsControl ItemsSource="{Binding SelectedFolders}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#F3F3F3" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Padding="6" Margin="4">
                                            <DockPanel>
                                                <TextBlock Text="{Binding Converter={StaticResource FolderShort}}" ToolTip="{Binding}" Margin="0,0,8,0"/>
                                                <!-- 修复点：Command 绑定到当前 ConvertViewModel -->
                                                <Button Content="x" Width="18" Height="18" Padding="0"
                                ToolTip="从列表移除此文件夹（不会删除磁盘文件）"
                                Command="{Binding DataContext.RemoveFolderCommand, RelativeSource={RelativeSource AncestorType=Grid}}"
                                CommandParameter="{Binding}"/>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </DockPanel>
                    </Border>

                    <!-- 中间：左树右预览 -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="420"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border BorderBrush="#DDD" BorderThickness="0,0,1,0">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="{Binding FileSummary}" Padding="10" Foreground="#555"/>
                                <TreeView ItemsSource="{Binding RootNodes}" SelectedItemChanged="TreeView_SelectedItemChanged">
                                    <TreeView.ItemTemplate>
                                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                            <TextBlock Text="{Binding DisplayName}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="Black"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsAlreadyTargetFormat}" Value="True">
                                                                <Setter Property="Foreground" Value="#999"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding HasError}" Value="True">
                                                                <Setter Property="Foreground" Value="IndianRed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </HierarchicalDataTemplate>
                                    </TreeView.ItemTemplate>
                                </TreeView>
                            </DockPanel>
                        </Border>

                        <Grid Grid.Column="1" Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="6" Padding="10">
                                <Grid>
                                    <Image Source="{Binding PreviewImage}" Stretch="Uniform"/>
                                    <TextBlock Text="选择左侧文件查看预览"
                             Foreground="#999" FontSize="18"
                             HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding PreviewImage}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Border>

                            <Border Grid.Row="1" Margin="0,10,0,0" Padding="10" Background="#FAFAFA" BorderBrush="#EEE" BorderThickness="1" CornerRadius="6">
                                <TextBlock Text="{Binding PreviewInfo}" Foreground="#444" TextWrapping="Wrap"/>
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- 底部：选项 + 执行 + 进度 -->
                    <Border Grid.Row="2" BorderBrush="#DDD" BorderThickness="0,1,0,0" Padding="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Vertical">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="目标格式：" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <ComboBox Width="120" ItemsSource="{Binding TargetFormats}" SelectedItem="{Binding SelectedTargetFormat}"/>

                                    <StackPanel Orientation="Horizontal" Margin="20,0,0,0" VerticalAlignment="Center"
                              Visibility="{Binding IsQualityRelevant, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Text="质量：" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <ComboBox Width="130" ItemsSource="{Binding JpegQualityModes}" SelectedItem="{Binding SelectedJpegQualityMode}"/>
                                        <Slider Width="160" Minimum="1" Maximum="100" Margin="10,0,0,0"
                            Value="{Binding JpegQuality}"
                            Visibility="{Binding IsCustomQualityMode, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                        <TextBlock Text="{Binding JpegQuality}" Margin="6,0,0,0" VerticalAlignment="Center"
                               Visibility="{Binding IsCustomQualityMode, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                        <TextBlock Text="背景：白" Margin="20,0,0,0" VerticalAlignment="Center" Foreground="#666"
                                        Visibility="{Binding IsJpegSelected, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    </StackPanel>

                                    <CheckBox Content="删除源文件（回收站）" Margin="20,0,0,0"
                            IsChecked="{Binding DeleteSourceToRecycleBin}"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0" VerticalAlignment="Center">
                                    <ProgressBar Width="420" Height="16" Minimum="0" Maximum="100" Value="{Binding ProgressPercent}"/>
                                    <TextBlock Text="{Binding ProgressText}" Margin="10,0,0,0" Foreground="#444" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="开始转换" Padding="16,8" Margin="10,0,0,0"
                        Command="{Binding StartConvertCommand}"
                        IsEnabled="{Binding CanStartConvert}"/>
                                <Button Content="取消" Padding="16,8" Margin="10,0,0,0"
                        Command="{Binding CancelCommand}"
                        IsEnabled="{Binding IsBusy}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- TAB2 -->
            <TabItem Header="查找相同图片">
                <Grid DataContext="{Binding Dedup}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 顶部：选择文件夹 + 阈值 -->
                    <Border BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <!-- 第一行：按钮/阈值等 -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="添加文件夹" Padding="12,6" Margin="0,0,10,0"
                    Command="{Binding AddFolderCommand}"/>

                                <CheckBox Content="递归子文件夹" Margin="0,0,10,0"
                      IsChecked="{Binding IsRecursive}"/>

                                <TextBlock Text="阈值：" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <Slider Width="220" Minimum="0" Maximum="3000" Value="{Binding Threshold}" />

                                <CheckBox Content="每次仅匹配当前文件夹内的图片"
                      Margin="20,0,0,0"
                      IsChecked="{Binding MatchWithinEachFolderOnly}"/>

                                <TextBlock Text="{Binding Threshold}" Margin="6,0,0,0" VerticalAlignment="Center"/>

                                <TextBlock Text="保留策略：" Margin="20,0,6,0" VerticalAlignment="Center"/>
                                <ComboBox Width="160" ItemsSource="{Binding KeepStrategies}" SelectedItem="{Binding SelectedKeepStrategy}"/>

                                <Button Content="查找相同图片" Padding="12,6" Margin="20,0,0,0"
                    Command="{Binding FindDuplicatesCommand}" IsEnabled="{Binding CanFind}"/>
                            </StackPanel>

                            <!-- 第二行：已选文件夹列表 -->
                            <ItemsControl Grid.Row="1" Margin="0,8,0,0" ItemsSource="{Binding SelectedFolders}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#F3F3F3" BorderBrush="#DDD" BorderThickness="1"
                            CornerRadius="4" Padding="6" Margin="4">
                                            <DockPanel>
                                                <TextBlock Text="{Binding Converter={StaticResource FolderShort}}"
                                       ToolTip="{Binding}" Margin="0,0,8,0"/>
                                                <Button Content="x" Width="18" Height="18" Padding="0"
                                    ToolTip="从列表移除此文件夹（不会删除磁盘文件）"
                                    Command="{Binding DataContext.RemoveFolderCommand, RelativeSource={RelativeSource AncestorType=Grid}}"
                                    CommandParameter="{Binding}"/>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>
                    <!-- 中间：相似组分页列表 -->
                    <Grid Grid.Row="1" Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Vertical" Margin="0,0,0,8">
                            <TextBlock Text="{Binding SummaryText}" Foreground="#555"/>
                            <TextBlock Text="{Binding CurrentPageTitle}" FontWeight="SemiBold" Margin="0,4,0,0"/>
                        </StackPanel>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding CurrentPageGroups}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                                            <StackPanel>
                                                <DockPanel>
                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                                                    <CheckBox DockPanel.Dock="Right" Content="本组仅保留最大分辨率，其余回收站"
                                    IsChecked="{Binding IsActionEnabled}"/>
                                                </DockPanel>

                                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="0,8,0,0">
                                                    <ItemsControl ItemsSource="{Binding Items}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <StackPanel Orientation="Horizontal"/>
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border BorderBrush="#EEE" BorderThickness="1" CornerRadius="4" Padding="6" Margin="0,0,10,0" Width="280">
                                                                    <StackPanel>
                                                                        <Image Source="{Binding Thumbnail}" Height="120" Stretch="Uniform"/>

                                                                        <TextBlock Text="{Binding Path, Converter={StaticResource FileShort}}"
                                                                                    ToolTip="{Binding Path}"
                                                                                    Margin="0,6,0,0"
                                                                                    TextWrapping="Wrap"
                                                                                    MaxHeight="36"/>
                                                                        <TextBlock Text="{Binding Meta}" Foreground="#666" FontSize="12" Margin="0,4,0,0"/>
                                                                    </StackPanel>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </ScrollViewer>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>

                    <!-- 底部：分页 + 全选/全不选 + 执行删除 + 进度 -->
                    <Border Grid.Row="2" BorderBrush="#DDD" BorderThickness="0,1,0,0" Padding="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="上一页" Padding="12,6" Command="{Binding PrevPageCommand}" IsEnabled="{Binding CanPrevPage}"/>
                                <Button Content="下一页" Padding="12,6" Margin="10,0,0,0" Command="{Binding NextPageCommand}" IsEnabled="{Binding CanNextPage}"/>
                                <TextBlock Text="{Binding PageText}" Margin="12,0,0,0" VerticalAlignment="Center"/>

                                <!-- 新增：全选/全不选（作用于所有组） -->
                                <Button Content="全选" Padding="12,6" Margin="20,0,0,0" Command="{Binding SelectAllGroupsCommand}" IsEnabled="{Binding HasGroups}"/>
                                <Button Content="全不选" Padding="12,6" Margin="10,0,0,0" Command="{Binding SelectNoneGroupsCommand}" IsEnabled="{Binding HasGroups}"/>

                                <ProgressBar Width="260" Height="16" Margin="20,0,0,0" Value="{Binding ProgressPercent}" Minimum="0" Maximum="100"/>
                                <TextBlock Text="{Binding ProgressText}" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="执行删除（回收站）" Padding="16,8" Command="{Binding ApplyDeleteCommand}" IsEnabled="{Binding CanApplyDelete}"/>
                                <Button Content="取消" Padding="16,8" Margin="10,0,0,0" Command="{Binding CancelCommand}" IsEnabled="{Binding IsBusy}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>